{
  "name": "gpu-memory-calculator",
  "version": "0.2.0",
  "description": "Professional LLM GPU Memory & Performance Simulator",
  "private": true,
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently \"next dev\" \"tsc -p electron/tsconfig.json && wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && tsc -p electron/tsconfig.json && electron-builder"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.6.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.gpu.simulator.new",
    "productName": "GPU Simulator Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/dist/**/*",
      "out/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
